# ══════════════════════════════════════════════════════════════════
#  Panimii Bakery — Variables de Entorno
#  Copia este archivo como .env y rellena los valores reales.
#  NUNCA subas el archivo .env real a GitHub.
# ══════════════════════════════════════════════════════════════════

# ── Django ──────────────────────────────────────────────────────
# Genera una clave con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=tu-clave-secreta-aqui

# True para desarrollo local, False en producción
DEBUG=True

# Hosts permitidos separados por coma (ej: localhost,127.0.0.1,tupaniimidominio.com)
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Base de Datos (MySQL en producción) ─────────────────────────
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
# Descomentar para MySQL:
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=panimii_db
# DB_USER=tu_usuario_mysql
# DB_PASSWORD=tu_password_mysql
# DB_HOST=localhost
# DB_PORT=3306

# ── Correo Electrónico (SMTP) ───────────────────────────────────
# Para Gmail: activa "Contraseñas de aplicación" en tu cuenta Google
# https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tucorreo@gmail.com
EMAIL_HOST_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Correo destino donde llegan los mensajes del formulario
EMAIL_DESTINATARIO=tucorreo@gmail.com
